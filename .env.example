# --- Supabase (required) ---
# Find these in: Supabase dashboard -> Project Settings -> API
# 1) Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# 2) Public "anon" key — safe to expose to the browser, used with RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 3) Service role key — SERVER ONLY, never expose to client.
# Bypasses RLS. Used by admin actions and server-side privileged queries
# (deposit approvals, withdraw approvals, admin dashboard reads, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
